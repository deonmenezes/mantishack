#!/usr/bin/env bash
#
# mantishack-agentic — thin libexec wrapper around `python3 mantishack.py agentic`.
#
# Lets .claude/commands/agentic.md invoke the agentic pipeline via a stable
# libexec command path that is allowlisted in .claude/settings.json, so the
# slash command does not trigger a permission prompt for `python3 mantishack.py`
# on every run.
#
# Usage:
#   libexec/mantishack-agentic --repo <path> [--understand] [--validate] [...]
#
# All arguments pass through to mantishack_agentic.py via mantishack.py.

set -euo pipefail

# ─── trust-marker check (do not source; inline by design) ───
if [ -z "${CLAUDECODE:-}" ] && [ -z "${_MANTISHACK_TRUSTED:-}" ]; then
    echo "$0: internal dispatch script." >&2
    echo "  Run via 'bin/mantishack' instead." >&2
    echo "  Tests / power users: set _MANTISHACK_TRUSTED=1 to bypass." >&2
    exit 2
fi
# ─── end trust-marker check ─────────────────────────────────

# Resolve symlinks so MANTISHACK_DIR is correct even when this wrapper is
# symlinked into ~/bin or similar (matches bin/mantishack's behaviour).
# Hop bound — see mantishack-cc-trust-check for the symlink-cycle rationale.
SCRIPT="$0"
_symhops=0
while [ -L "$SCRIPT" ]; do
    _symhops=$((_symhops + 1))
    if [ "$_symhops" -gt 32 ]; then
        echo "mantishack-agentic: symlink hop limit exceeded resolving $0" >&2
        exit 1
    fi
    DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
    SCRIPT="$(readlink "$SCRIPT")"
    [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
unset _symhops
MANTISHACK_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

# Defensive: confirm we're really inside a MANTISHACK install before exec'ing
# python3 on what might be a missing path. Fails loudly if symlink-walk
# resolved to somewhere unexpected.
#
# Order: this check runs BEFORE sourcing _dangerous_env_strip.sh below
# so a broken-install path produces the explanatory "cannot find
# mantishack.py" message rather than bash's confusing
# "No such file or directory" on the source line. The strip script
# lives next to mantishack.py, so if mantishack.py is missing the strip script
# is also missing, and the test harness expects the friendlier error.
if [ ! -f "$MANTISHACK_DIR/mantishack.py" ]; then
    echo "mantishack-agentic: cannot find mantishack.py under $MANTISHACK_DIR" >&2
    echo "mantishack-agentic: (resolved from $SCRIPT)" >&2
    exit 1
fi

# Strip env vars that could inject code into the Python process.
# Same single-source-of-truth as bin/mantishack and bin/cve-diff. Pre-fix
# this wrapper relied on the parent (bin/mantishack) having already stripped
# — which is true for the default invocation path, but power users who
# set `_MANTISHACK_TRUSTED=1` and call the wrapper directly bypassed the
# strip entirely. Apply it here too so the trusted-direct path has the
# same env-hygiene floor as the bin/mantishack → libexec/ path.
. "$MANTISHACK_DIR/core/security/_dangerous_env_strip.sh"

exec python3 "$MANTISHACK_DIR/mantishack.py" agentic "$@"
