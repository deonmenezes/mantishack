#!/usr/bin/env python3
"""SessionStart hook: env file setup and startup banner.

Called automatically by Claude Code on session start (via .claude/settings.json).
Writes MANTISHACK_DIR + PATH to the env file (overwrite, not append) and generates
the startup banner in .startup-output.

No project env vars are set — the .active symlink is the only source of truth.
"""
import os
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
# ─── trust-marker check (do not import; inline by design) ───
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_MANTISHACK_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/mantishack' instead.\n"
        "  Tests / power users: set _MANTISHACK_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(REPO_ROOT))


def write_env_file():
    """Write the env file with static vars. Overwrites to ensure clean state."""
    env_file = os.environ.get("CLAUDE_ENV_FILE")
    if not env_file:
        return

    repo_root = str(REPO_ROOT)
    bin_dir = str(REPO_ROOT / "bin")

    content = (
        f'export MANTISHACK_DIR="{repo_root}"\n'
        f'export PATH="$PATH:{bin_dir}"\n'
    )

    try:
        Path(env_file).write_text(content)
    except OSError:
        pass


def generate_banner():
    """Generate the startup banner and write to .startup-output."""
    output_file = REPO_ROOT / ".startup-output"

    # MANTISHACK requires Python 3.10+. core.startup.init uses PEP 604
    # `X | Y` annotations at definition time, so it fails to *import* on
    # 3.9 with a confusing "unsupported operand type(s) for |" TypeError.
    # Catch that here and write a clear, actionable message instead.
    if sys.version_info < (3, 10):
        found = ".".join(str(n) for n in sys.version_info[:3])
        try:
            output_file.write_text(
                f"MANTISHACK requires Python 3.10 or later — found {found}.\n"
                "Launch via 'bin/mantishack' or activate the repo's .venv "
                "(which ships a supported interpreter).\n"
            )
        except OSError:
            pass
        return

    try:
        from core.startup.init import main as init_main
        init_main()
    except Exception as e:
        # Non-fatal — write a minimal banner
        try:
            output_file.write_text(f"MANTISHACK startup error: {e}\n")
        except OSError:
            pass


if __name__ == "__main__":
    write_env_file()
    generate_banner()
