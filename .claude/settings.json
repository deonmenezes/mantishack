{
  "env": {
    "CLAUDE_ENV_FILE": ".claude/mantishack.env",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "permissions": {
    "allow": [
      "Bash(libexec/mantishack-agentic *)",
      "Bash(libexec/mantishack-build-checklist *)",
      "Bash(libexec/mantishack-coverage-summary *)",
      "Bash(libexec/mantishack-normalize-context-map *)",
      "Bash(libexec/mantishack-project-manager *)",
      "Bash(libexec/mantishack-render-diagrams *)",
      "Bash(libexec/mantishack-run-feasibility *)",
      "Bash(libexec/mantishack-run-lifecycle *)",
      "Bash(libexec/mantishack-run-sandboxed *)",
      "Bash(libexec/mantishack-sandbox-summary *)",
      "Bash(libexec/mantishack-startup-check *)",
      "Bash(libexec/mantishack-validate-schema *)",
      "Bash(libexec/mantishack-validation-helper *)",
      "Write(/out/**)",
      "Edit(/out/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/libexec/mantishack-session-init\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/libexec/mantishack-lifecycle-hook\" stop"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(libexec/mantishack-*)",
            "command": "\"$CLAUDE_PROJECT_DIR/libexec/mantishack-lifecycle-hook\" tool-failure"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/libexec/mantishack-lifecycle-hook\" session-end"
          }
        ]
      }
    ]
  }
}
